Task-2:

# Create 20 text files: file1.txt to file20.txt
touch file{1..20}.txt

# Correct command to list files with details
ls -l

# Loop to rename first 5 files from .txt to .yml
for i in {1..5};
do
  mv file$i.txt file$i.yml
done

# List files sorted by latest modified time and show top 5
ls -t | head -5



