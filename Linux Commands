Task-1:

# Create a directory named my_folder
mkdir my_folder

# Move into the directory
cd my_folder/

# Create an empty file
touch my_file.txt

# Open file in vim editor and add content
vim my_file.txt

# Display content of my_file.txt
cat my_file.txt

# Create another file
touch nother_file.txt

# Open second file in vim and add content
vim nother_file.txt

# Display content of second file
cat nother_file.txt

# Append content of nother_file.txt to my_file.txt
cat nother_file.txt >> my_file.txt

# Display updated content of my_file.txt
cat my_file.txt

